---
import Base from '../layouts/Base.astro';
import { readFileSync } from 'node:fs';
import { fileURLToPath } from 'node:url';
import { dirname, join } from 'node:path';
import { parse } from 'yaml';

const __dirname = dirname(fileURLToPath(import.meta.url));
const root = join(__dirname, '..', '..');
const doc = parse(readFileSync(join(root, 'data', 'plans.yaml'), 'utf8'));

const PRICE_CAP = doc.meta.price_cap || 150;
const USD2CNY = 7.2;
function cnyPrice(p) { return p.currency === 'usd' ? p.price_monthly * USD2CNY : p.price_monthly; }

function capaPts(p) { const r = p.capability_rank; return r === 1 ? 50 : r === 2 ? 30 : r === 3 ? 20 : 0; }
function pricePts(p) { const c = cnyPrice(p); return c <= 50 ? 50 : c <= 100 ? 30 : 20; }
const maxRefill = Math.max(...doc.plans.map(p => p.refill_month ?? 0), 1);
function quotaPts(p) { return ((p.refill_month ?? 0) / maxRefill) * 50; }

let filtered = doc.plans.filter(p => cnyPrice(p) <= PRICE_CAP && [1, 2, 3].includes(p.capability_rank));

const scored = filtered
  .map(p => {
    const cp = capaPts(p), pp = pricePts(p), qp = quotaPts(p);
    const total = cp * 0.40 + pp * 0.30 + qp * 0.30;
    return { ...p, capa_pts: cp, price_pts: pp, quota_pts: Number(qp.toFixed(2)), total_score: Number(total.toFixed(2)) };
  })
  .sort((a, b) => b.total_score - a.total_score);

const userOrder = ['volcengine-lite', 'opencode-go', 'glm-lite', 'glm-pro', 'minimax-plus'];
const featured = userOrder.map(id => scored.find(p => p.id === id)).filter(Boolean);
for (const s of scored) { if (!featured.find(p => p.id === s.id)) featured.push(s); }
const top = featured[0];
const meta = doc.meta;

function fmtPrice(p) { return p.currency === 'usd' ? `$${p.price_monthly}` : `¥${p.price_monthly}`; }
function fmtTokens(m) { if (!m) return '—'; return m >= 1000 ? `${(m / 1000).toFixed(2)}B` : `${m}M`; }
function fmtRefill(n) { if (!n) return '—'; return n >= 10000 ? `${(n / 10000).toFixed(1)}万` : n.toLocaleString(); }
const maxScore = featured[0]?.total_score ?? 10;
const minScore = featured[featured.length - 1]?.total_score ?? 0;
function barWidth(s) { return ((s - minScore) / Math.max(1e-9, maxScore - minScore)) * 100; }
function firstPrice(note) {
  const m = note.match(/首月[¥$]?([\d.]+)/);
  return m ? m[1] : null;
}
---

<Base path="/" title="AI 编程订阅 · 选最值的">
  <section class="wrap hero">
    <p class="eyebrow"><span class="bar"></span>AI 编程 · 怎么选最值</p>
    <h1>每月不超<span class="accent">¥{PRICE_CAP}</span>，<br/>模型就得用最强的。</h1>
    <p class="lede">从几十款套餐里筛出真正值得买的——价格不超¥{PRICE_CAP}、模型T0、用量扛造。不藏着掖着，怎么算的写在<a href="/method">方法页</a>里。</p>
    <p class="meta">更新于 {meta.updated} · {featured.length} 款过线</p>
  </section>

  <section class="wrap">
    <div class="answer">
      <div class="label">最值的一单</div>
      <div class="name">{top.platform} · {top.plan}</div>
      <p class="why">{top.note}</p>
      <div class="score-row">
        <div><div class="k">综合分</div><div class="v"><span class="accent">{top.total_score}</span><span style="color:var(--ink-faint)"> / 100</span></div></div>
        <div><div class="k">能力分</div><div class="v num">{top.capa_pts}</div></div>
        <div><div class="k">价格分</div><div class="v num">{top.price_pts}</div></div>
        <div><div class="k">用量分</div><div class="v num">{top.quota_pts}</div></div>
      </div>
      <div style="margin-top:1.2rem">
        <a class="go-btn" href={top.affiliate_url || top.official_url} target="_blank" rel={top.affiliate_url ? 'noopener sponsored' : 'noopener nofollow'}>官方订阅 →</a>
      </div>
    </div>
  </section>

  <section class="wrap">
    <p class="eyebrow"><span class="bar"></span>过线排名 Top {featured.length}</p>
    <h2>预算以内，这几款值得看。</h2>
    <div class="cards">
      {featured.map((p, i) => (
        <article class="card">
          <div class="rank num">No. {String(i + 1).padStart(2, '0')}</div>
          <div class="platform">{p.platform}</div>
          <div class="plan"><a href={p.affiliate_url || p.official_url} target="_blank" rel={p.affiliate_url ? 'noopener sponsored' : 'noopener nofollow'}>{p.plan}</a></div>
          <div class="specs">
            <span class="k">旗舰模型</span><span class="v">{p.model_flagship}</span>
            <span class="k">月费</span><span class="v">{fmtPrice(p)}</span>
            {p.measured_monthly_tokens_M && <><span class="k">月可用 Token</span><span class="v">{fmtTokens(p.measured_monthly_tokens_M)}</span></>}
            {p.first_price && <><span class="k">首月</span><span class="v">{firstPrice(p.note)}</span></>}
            <span class="k">抢购</span><span class="v">{p.purchase_difficulty === 'easy' ? '无需' : p.purchase_difficulty === 'normal' ? '一般' : '需抢'}</span>
          </div>
          <p class="note">{p.note}</p>
          <div class="foot">
            <div class="score num"><span class="accent">{p.total_score}</span><span style="color:var(--ink-faint)"> / 100</span></div>
            <span class="verdict {p.verdict}">{p.verdict}</span>
          </div>
          <a class="goto" href={p.affiliate_url || p.official_url} target="_blank" rel={p.affiliate_url ? 'noopener sponsored' : 'noopener nofollow'}>官方订阅 →</a>
        </article>
      ))}
    </div>
  </section>

  <section class="wrap">
    <p class="eyebrow"><span class="bar"></span>综合分对比</p>
    <h2>谁最值，一眼看清。</h2>
    <div class="metric-bar">
      {featured.map(p => (
        <div class={`row ${p === top ? 'top' : ''}`}>
          <div class="label">{p.platform} · {p.plan}</div>
          <div class="track"><div class="fill" style={`width:${barWidth(p.total_score)}%`}></div></div>
          <div class="val num">{p.total_score}</div>
        </div>
      ))}
    </div>
    <p style="color:var(--ink-faint);font-size:.85rem;margin-top:1rem">
      综合分 = 能力×40% + 价格×30% + 用量×30%。不超过¥{PRICE_CAP}、模型≥国内前3。<a href="/method">方法说明 →</a>
    </p>
  </section>

  <section class="wrap" style="margin-top:4rem;padding-bottom:2rem">
    <p style="color:var(--ink-soft)"><b>不确定买哪个？</b> <a href="/calculator">用计算器，4 个问题给一个答案 →</a></p>
    <p style="color:var(--ink-soft);margin-top:.5rem">或者 <a href="/table">直接看 {doc.plans.length - featured.length} 款未过线的全套 →</a></p>
  </section>

  <section class="wrap" style="padding-bottom:2rem">
    <p class="eyebrow"><span class="bar"></span>模型能力排名</p>
    <h2>谁最强，一目了然。</h2>
    <p style="color:var(--ink-soft);max-width:62ch;margin-bottom:1.5rem">
      数据来自 <a href="https://artificialanalysis.ai/leaderboards/models" target="_blank" rel="noopener">Artificial Analysis</a> Intelligence Index v4.1，综合 9 项独立评测。前 10 名如下，<a href="/rankings">完整 25 名 →</a>
    </p>
    <div class="chart-home">
      {[
        { rank: 1, name: 'Claude Fable 5', org: 'Anthropic', score: 60, flag: '🇺🇸' },
        { rank: 2, name: 'Claude Opus 4.8', org: 'Anthropic', score: 56, flag: '🇺🇸' },
        { rank: 3, name: 'GPT-5.5', org: 'OpenAI', score: 55, flag: '🇺🇸' },
        { rank: 4, name: 'Claude Opus 4.7', org: 'Anthropic', score: 54, flag: '🇺🇸' },
        { rank: 5, name: 'Claude Sonnet 5', org: 'Anthropic', score: 53, flag: '🇺🇸' },
        { rank: 6, name: 'GPT-5.5 (high)', org: 'OpenAI', score: 53, flag: '🇺🇸' },
        { rank: 7, name: 'GLM-5.2', org: 'Z AI', score: 51, flag: '🇨🇳' },
        { rank: 8, name: 'GPT-5.5 (medium)', org: 'OpenAI', score: 50, flag: '🇺🇸' },
        { rank: 9, name: 'Gemini 3.5 Flash', org: 'Google', score: 50, flag: '🇺🇸' },
        { rank: 10, name: 'Gemini 3.1 Pro', org: 'Google', score: 46, flag: '🇺🇸' },
      ].map(m => {
        const pct = (m.score / 60) * 100;
        const isCN = ['Z AI', 'Alibaba', 'MiniMax', 'DeepSeek', 'Kimi', 'Xiaomi', 'Nex AGI'].includes(m.org);
        return (
          <div class="bar-row">
            <div class="bar-rank num">{m.rank}</div>
            <div class="bar-label">
              <span class="bar-name">{m.flag} {m.name}</span>
              <span class="bar-org">{m.org}</span>
            </div>
            <div class="bar-track">
              <div class="bar-fill" style={`width:${pct}%`} data-cn={isCN ? '1' : '0'}></div>
            </div>
            <div class="bar-score num">{m.score}</div>
          </div>
        );
      })}
    </div>
    <div class="legend" style="margin-top:1rem;display:flex;gap:1.5rem;font-size:.82rem;color:var(--ink-soft)">
      <span><span style="display:inline-block;width:.8rem;height:.8rem;background:var(--accent);border-radius:2px;vertical-align:middle;margin-right:.3rem"></span>国内可订阅</span>
      <span><span style="display:inline-block;width:.8rem;height:.8rem;background:var(--ink-faint);border-radius:2px;vertical-align:middle;margin-right:.3rem"></span>海外为主</span>
    </div>
    <p style="color:var(--ink-faint);font-size:.82rem;margin-top:.8rem">
      评分截至 2026-07-03 · 来源：<a href="https://artificialanalysis.ai/leaderboards/models" target="_blank" rel="noopener">Artificial Analysis</a>
    </p>
  </section>

  <section class="wrap" style="padding-bottom:3rem">
    <p class="eyebrow"><span class="bar"></span>开源</p>
    <h2>数据全公开</h2>
    <p style="color:var(--ink-soft);max-width:56ch">
      本站全部数据、评分脚本、页面源码均在 GitHub 公开。欢迎监督、纠错、PR。
    </p>
    <span class="github-link" style="opacity:.4;cursor:not-allowed">
      GitHub → Non-existent987/codingplan（备案后开放）
    </span>
  </section>
</Base>

<style>
  .chart-home {
    max-width: 780px;
  }
  .bar-row {
    display: grid;
    grid-template-columns: 2.5rem 1fr 2fr 3rem;
    align-items: center;
    gap: .6rem;
    margin-bottom: .35rem;
  }
  .bar-rank {
    text-align: right;
    font-size: .85rem;
    color: var(--ink-faint);
  }
  .bar-label {
    display: flex;
    flex-direction: column;
    min-width: 0;
  }
  .bar-name {
    font-size: .88rem;
    font-weight: 500;
    color: var(--ink);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .bar-org {
    font-size: .72rem;
    color: var(--ink-faint);
  }
  .bar-track {
    height: 1.4rem;
    background: var(--rule-soft);
    border-radius: 3px;
    overflow: hidden;
  }
  .bar-fill {
    height: 100%;
    border-radius: 3px;
    transition: width .6s ease;
  }
  .bar-fill[data-cn="1"] {
    background: var(--accent);
  }
  .bar-fill[data-cn="0"] {
    background: var(--ink-faint);
  }
  .bar-score {
    font-size: .9rem;
    font-weight: 500;
    color: var(--accent);
    text-align: left;
  }
  .github-link {
    display: inline-block;
    margin-top: 1rem;
    font-family: var(--mono);
    font-size: .88rem;
    color: var(--accent);
    text-decoration: none;
    border: 1px solid var(--accent);
    padding: .5rem 1rem;
    border-radius: 4px;
    transition: background .15s;
  }
  .github-link:hover {
    background: var(--accent-soft);
  }
  @media (max-width: 640px) {
    .bar-row {
      grid-template-columns: 2rem 1fr 1.5fr 2.5rem;
      gap: .4rem;
    }
    .bar-name { font-size: .78rem; }
    .bar-track { height: 1.1rem; }
  }
</style>