---
import Base from '../layouts/Base.astro';
import { readFileSync } from 'node:fs';
import { fileURLToPath } from 'node:url';
import { dirname, join } from 'node:path';
import { parse } from 'yaml';

const __dirname = dirname(fileURLToPath(import.meta.url));
const root = join(__dirname, '..', '..');
const doc = parse(readFileSync(join(root, 'data', 'plans.yaml'), 'utf8'));

const PRICE_CAP = doc.meta.price_cap || 150;
const USD2CNY = 7.2;
const MAX_REFILL = 200000;
function cnyPrice(p) { return p.currency === 'usd' ? p.price_monthly * USD2CNY : p.price_monthly; }
function capaPts(p) { const r = p.capability_rank; return r === 1 ? 50 : r === 2 ? 25 : r === 3 ? 10 : r === 4 ? 5 : 0; }
function pricePts(p) { return Math.max(0, Math.min(50, 50 * (1 - cnyPrice(p) / 150))); }
function quotaPts(p) { return Math.min(50, ((p.refill_month ?? 0) / MAX_REFILL) * 50); }

const PROVIDER_MAP = [
  ['GLM','Z AI'],['DeepSeek','DeepSeek'],['Kimi','Kimi'],
  ['MiniMax','MiniMax'],['Qwen','Alibaba'],['MiMo','Xiaomi'],
  ['Doubao','ByteDance'],['ERNIE','Baidu'],['Hunyuan','Tencent'],['Pangu','Huawei'],
];
function modelProviders(models) {
  if (!models||!models.length) return new Set();
  const ps = new Set();
  for (const m of models) { for (const [prefix, name] of PROVIDER_MAP) { if (m.startsWith(prefix)) { ps.add(name); break; } } }
  return ps;
}
function calcBonus(p) {
  let pts = 0; const n = (p.models||[]).length;
  if (n >= 8) pts += 4; else if (n >= 6) pts += 3; else if (n >= 4) pts += 2; else if (n >= 2) pts += 1;
  if (p.purchase_difficulty === 'easy') pts += 2; else if (p.purchase_difficulty === 'normal') pts += 1;
  if (p.note && /首月/.test(p.note)) pts += 2;
  const pCount = modelProviders(p.models||[]).size;
  if (pCount >= 4) pts += 3; else if (pCount >= 3) pts += 2; else if (pCount >= 2) pts += 1;
  if (p.capability_rank === 1) pts += 3; else if (p.capability_rank === 2) pts += 2; else if (p.capability_rank === 3) pts += 1;
  if (p.region === 'cn') pts += 1;
  return Math.min(pts, 20);
}

const filtered = doc.plans.filter(p => cnyPrice(p) <= PRICE_CAP && [1,2,3,4].includes(p.capability_rank));
const scored = filtered.map(p => {
  const cp = capaPts(p), pp = pricePts(p), qp = quotaPts(p);
  const total = Math.min(100, cp * 0.80 + pp * 0.60 + qp * 0.60 + calcBonus(p));
  return { ...p, capa_pts: cp, price_pts: Number(pp.toFixed(2)), quota_pts: Number(qp.toFixed(2)), bonus_pts: calcBonus(p), total_score: Number(total.toFixed(2)) };
}).sort((a, b) => b.total_score - a.total_score);

const outOfBand = doc.plans
  .filter(p => !(cnyPrice(p) <= PRICE_CAP && [1, 2, 3, 4].includes(p.capability_rank)))
  .map(p => {
    const reasons = [];
    if (cnyPrice(p) > PRICE_CAP) reasons.push(`超¥${PRICE_CAP}`);
    if (![1, 2, 3, 4].includes(p.capability_rank)) reasons.push(`模型未进国内前3`);
    return { ...p, oob_reason: reasons.join('；'), capa_pts: 0, price_pts: 0, quota_pts: 0, bonus_pts: 0, total_score: 0 };
  });

const ranked = [...scored, ...outOfBand];

function fmtPrice(p) { return p.currency === 'usd' ? `$${p.price_monthly}` : `¥${p.price_monthly}`; }
---

<Base path="/table" title="全部套餐 · Coding Plan Guide">
  <section class="wrap" style="padding-top:3rem">
    <p class="eyebrow"><span class="bar"></span>全部套餐</p>
    <h2>{ranked.length} 款，过线 {scored.length} 款。</h2>
    <p style="color:var(--ink-soft);max-width:54ch">首 {scored.length} 款为过线排名（价格≤¥{PRICE_CAP} + 能力≥国内前3），其余按"未通过原因"附下。</p>

    <p style="margin:1.6rem 0 0">
      <button id="toggle-less" type="button"
        style="border:1px solid var(--rule);background:transparent;padding:.55rem 1rem;font-family:var(--sans);font-size:.88rem;cursor:pointer;color:var(--ink)">
        显示全部 {ranked.length} 款 <span style="color:var(--accent)">↓</span>
      </button>
    </p>

    <div style="margin-top:2rem; overflow-x:auto">
      <table class="thin-table" id="plan-table">
        <thead>
          <tr>
            <th data-key="rank">#</th>
            <th data-key="platform">平台 · 套餐</th>
            <th data-key="type">类型</th>
            <th data-key="price_monthly" data-num>月费</th>
            <th data-key="capability_rank" data-num>模型排名</th>
            <th data-key="total_score" data-num>综合分</th>
            <th data-key="verdict">结论</th>
            <th>购买</th>
          </tr>
        </thead>
        <tbody>
          {ranked.map((p, i) => (
            <tr class={i >= scored.length ? 'extra' : ''} style={i >= scored.length ? 'display:none' : ''}>
              <td class="num">{i + 1}</td>
              <td><b><a href={p.affiliate_url || p.official_url} target="_blank" rel={p.affiliate_url ? 'sponsored' : 'nofollow'} style="border:none;color:var(--ink)">{p.platform}</a></b> · <a href={p.affiliate_url || p.official_url} target="_blank" rel={p.affiliate_url ? 'sponsored' : 'nofollow'} style="border:none;color:var(--ink-soft)">{p.plan}</a></td>
              <td>{p.type === 'coding' ? 'Coding' : 'Token'}</td>
              <td class="num">{fmtPrice(p)}</td>
              <td class="num">{p.capability_rank === 1 ? '1st' : p.capability_rank === 2 ? '2nd' : p.capability_rank === 3 ? '3rd' : '—'}</td>
              <td class="num"><b style="color:var(--accent)">{p.total_score || '—'}</b></td>
              <td>
                <span class="verdict-dot {p.verdict}"></span>{p.verdict}
                {p.oob_reason ? <span style="font-size:.7rem;color:var(--ink-faint);display:block">({p.oob_reason})</span> : ''}
              </td>
              <td>
                <a href={p.affiliate_url || p.official_url} target="_blank" rel={p.affiliate_url ? 'sponsored' : 'nofollow'} style="font-size:.78rem;border:1px solid var(--accent);color:var(--accent);padding:.1rem .4rem;text-decoration:none">官方订阅</a>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <p style="color:var(--ink-faint);font-size:.82rem;margin-top:1.4rem">评分公式见 <a href="/method">方法说明</a>。</p>
  </section>
</Base>

<script is:inline define:vars={{ scoredLen: scored.length }}>
  const btn = document.getElementById('toggle-less');
  const extras = document.querySelectorAll('tr.extra');
  let expanded = false;
  btn.addEventListener('click', () => {
    expanded = !expanded;
    extras.forEach(r => r.style.display = expanded ? '' : 'none');
    btn.innerHTML = expanded
      ? '只显示过线 ' + scoredLen + ' 款 <span style="color:var(--accent)">↑</span>'
      : '显示全部 <span style="color:var(--accent)">↓</span>';
  });

  const table = document.getElementById('plan-table');
  const tbody = table.querySelector('tbody');
  let sortKey = 'rank', sortDir = 1;
  table.querySelectorAll('th:not(:last-child)').forEach(th => {
    th.addEventListener('click', () => {
      const key = th.dataset.key;
      if (sortKey === key) sortDir = -sortDir; else { sortKey = key; sortDir = 1; }
      table.querySelectorAll('th').forEach(h => h.classList.remove('sorted'));
      th.classList.add('sorted');
      const rows = Array.from(tbody.querySelectorAll('tr'));
      rows.sort((a, b) => {
        let av, bv;
        if (key === 'platform') { av = a.cells[1].textContent; bv = b.cells[1].textContent; return av.localeCompare(bv, 'zh') * sortDir; }
        else if (key === 'verdict') { av = a.cells[6].textContent.trim(); bv = b.cells[6].textContent.trim(); return av.localeCompare(bv, 'zh') * sortDir; }
        else {
          av = parseFloat(a.cells[key === 'rank' ? 0 : key === 'price_monthly' ? 3 : key === 'capability_rank' ? 4 : 5].textContent) || 0;
          bv = parseFloat(b.cells[key === 'rank' ? 0 : key === 'price_monthly' ? 3 : key === 'capability_rank' ? 4 : 5].textContent) || 0;
          return (av - bv) * sortDir;
        }
      });
      rows.forEach(r => tbody.appendChild(r));
    });
  });
</script>