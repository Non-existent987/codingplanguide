---
import Base from '../layouts/Base.astro';

const models = [
  { rank: 1, name: 'Claude Fable 5', org: 'Anthropic', score: 60 },
  { rank: 2, name: 'Claude Opus 4.8', org: 'Anthropic', score: 56 },
  { rank: 3, name: 'GPT-5.5', org: 'OpenAI', score: 55 },
  { rank: 4, name: 'Claude Opus 4.7', org: 'Anthropic', score: 54 },
  { rank: 5, name: 'Claude Sonnet 5', org: 'Anthropic', score: 53 },
  { rank: 6, name: 'GPT-5.5', org: 'OpenAI', score: 53, note: 'high' },
  { rank: 7, name: 'GLM-5.2', org: 'Z AI', score: 51, note: 'max' },
  { rank: 8, name: 'GPT-5.5', org: 'OpenAI', score: 50, note: 'medium' },
  { rank: 9, name: 'Gemini 3.5 Flash', org: 'Google', score: 50 },
  { rank: 10, name: 'Gemini 3.1 Pro', org: 'Google', score: 46 },
  { rank: 11, name: 'Qwen3.7 Max', org: 'Alibaba', score: 46 },
  { rank: 12, name: 'MiniMax-M3', org: 'MiniMax', score: 44 },
  { rank: 13, name: 'DeepSeek V4 Pro', org: 'DeepSeek', score: 44, note: 'max' },
  { rank: 14, name: 'GPT-5.3 Codex', org: 'OpenAI', score: 44, note: 'xhigh' },
  { rank: 15, name: 'Kimi K2.6', org: 'Kimi', score: 43 },
  { rank: 16, name: 'MiMo-V2.5-Pro', org: 'Xiaomi', score: 42 },
  { rank: 17, name: 'Kimi K2.7 Code', org: 'Kimi', score: 42 },
  { rank: 18, name: 'Nex-N2-Pro', org: 'Nex AGI', score: 41 },
  { rank: 19, name: 'DeepSeek V4 Pro', org: 'DeepSeek', score: 41, note: 'high' },
  { rank: 20, name: 'DeepSeek V4 Flash', org: 'DeepSeek', score: 40, note: 'max' },
];

const maxScore = models[0].score;
const minScore = models[models.length - 1].score;
---

<Base path="/rankings" title="模型能力排名 · Coding Plan Guide">
  <section class="wrap" style="padding-top:3rem">
    <p class="eyebrow"><span class="bar"></span>模型能力排名</p>
    <h2>谁最强，一目了然。</h2>
    <p style="color:var(--ink-soft);max-width:62ch;margin-bottom:2rem">
      数据来自 <a href="https://artificialanalysis.ai/leaderboards/models" target="_blank" rel="noopener">Artificial Analysis</a> Intelligence Index v4.1，
      综合了 GDPval-AA v2、Terminal-Bench v2.1、SciCode、HLE、GPQA Diamond 等 9 项评测。
      排名前 20 的模型如下。
    </p>

    <div class="chart">
      {models.map(m => {
        const pct = (m.score / maxScore) * 100;
        const label = m.note ? `${m.name} (${m.note})` : m.name;
        const isCN = ['Z AI', 'Alibaba', 'MiniMax', 'DeepSeek', 'Kimi', 'Xiaomi', 'Nex AGI'].includes(m.org);
        return (
          <div class="bar-row">
            <div class="bar-rank num">{m.rank}</div>
            <div class="bar-label">
              <span class="bar-name">{label}</span>
              <span class="bar-org">{m.org}</span>
            </div>
            <div class="bar-track">
              <div class="bar-fill" style={`width:${pct}%`} data-cn={isCN ? '1' : '0'}></div>
            </div>
            <div class="bar-score num">{m.score}</div>
          </div>
        );
      })}
    </div>

    <div class="legend" style="margin-top:1.5rem;display:flex;gap:1.5rem;font-size:.82rem;color:var(--ink-soft)">
      <span><span style="display:inline-block;width:.8rem;height:.8rem;background:var(--accent);border-radius:2px;vertical-align:middle;margin-right:.3rem"></span>国内可订阅</span>
      <span><span style="display:inline-block;width:.8rem;height:.8rem;background:var(--ink-faint);border-radius:2px;vertical-align:middle;margin-right:.3rem"></span>海外为主</span>
    </div>

    <p style="color:var(--ink-faint);font-size:.82rem;margin-top:1.2rem">
      评分截至 2026-07-03。完整榜单见 <a href="https://artificialanalysis.ai/leaderboards/models" target="_blank" rel="noopener">Artificial Analysis</a>。
    </p>
  </section>

  <section class="wrap" style="padding-bottom:3rem">
    <p class="eyebrow"><span class="bar"></span>OpenCode Go 模型用量</p>
    <h2>7 大模型，各有多少请求？</h2>
    <p style="color:var(--ink-soft);max-width:62ch;margin-bottom:1.5rem">
      OpenCode Go 包含 7 大模型，各模型独立请求配额。DeepSeek V4 Flash 月 15.8 万次，搭配 GLM-5.2 旗舰使用，日常编程几乎用不完。流畅无中断、无告警、无扣量问题。
    </p>
    <div style="overflow-x:auto">
      <table class="thin-table">
        <thead>
          <tr>
            <th>模型</th>
            <th>每5小时</th>
            <th>每周</th>
            <th>每月</th>
            <th>AA全球排名</th>
          </tr>
        </thead>
        <tbody>
          {[
            { name: 'GLM-5.2', h5: 880, week: 2150, month: 4300, aa: 7 },
            { name: 'DeepSeek V4 Pro', h5: 3450, week: 8550, month: 17150, aa: 13 },
            { name: 'DeepSeek V4 Flash', h5: 31650, week: 79050, month: 158150, aa: 20 },
            { name: 'Kimi K2.7 Code', h5: 1350, week: 4630, month: 9250, aa: 17 },
            { name: 'MiniMax M3', h5: 3200, week: 8000, month: 16000, aa: 12 },
            { name: 'Qwen3.7 Max', h5: 950, week: 2390, month: 4770, aa: 11 },
            { name: 'MiMo-V2.5-Pro', h5: 3250, week: 8150, month: 16300, aa: 16 },
          ].map(m => (
            <tr>
              <td><b>{m.name}</b></td>
              <td class="num">{m.h5.toLocaleString()}</td>
              <td class="num">{m.week.toLocaleString()}</td>
              <td class="num">{m.month.toLocaleString()}</td>
              <td class="num">#{m.aa}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
    <div style="margin-top:1.5rem">
      <a class="goto" href="https://opencode.ai/go?ref=F3C3Y1MVK0" target="_blank" rel="noopener sponsored">官方订阅 OpenCode Go →</a>
    </div>
  </section>
</Base>

<style>
  .chart {
    max-width: 820px;
  }
  .bar-row {
    display: grid;
    grid-template-columns: 2.5rem 1fr 2fr 3rem;
    align-items: center;
    gap: .6rem;
    margin-bottom: .35rem;
  }
  .bar-rank {
    text-align: right;
    font-size: .85rem;
    color: var(--ink-faint);
  }
  .bar-label {
    display: flex;
    flex-direction: column;
    min-width: 0;
  }
  .bar-name {
    font-size: .88rem;
    font-weight: 500;
    color: var(--ink);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .bar-org {
    font-size: .72rem;
    color: var(--ink-faint);
  }
  .bar-track {
    height: 1.4rem;
    background: var(--rule-soft);
    border-radius: 3px;
    overflow: hidden;
    position: relative;
  }
  .bar-fill {
    height: 100%;
    border-radius: 3px;
    transition: width .6s ease;
  }
  .bar-fill[data-cn="1"] {
    background: var(--accent);
  }
  .bar-fill[data-cn="0"] {
    background: var(--ink-faint);
  }
  .bar-score {
    font-size: .9rem;
    font-weight: 500;
    color: var(--accent);
    text-align: left;
  }

  @media (max-width: 640px) {
    .bar-row {
      grid-template-columns: 2rem 1fr 1.5fr 2.5rem;
      gap: .4rem;
    }
    .bar-name { font-size: .78rem; }
    .bar-track { height: 1.1rem; }
  }
</style>
